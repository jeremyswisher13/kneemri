      "url": "/courses/knee-mri/normal-knee-mri",
      "icons": [{ "src": "/pwa-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Normal Shoulder MRI",
      "short_name": "Shoulder",
      "description": "Open the interactive normal shoulder MRI workstation.",
      "url": "/courses/shoulder-mri/normal-shoulder-mri",
      "icons": [{ "src": "/pwa-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Normal Hip MRI",
      "short_name": "Hip",
      "description": "Open the interactive normal hip MRI workstation.",
      "url": "/courses/hip-mri/normal-hip-mri",
      "icons": [{ "src": "/pwa-icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Normal Elbow MRI",
      "short_name": "Elbow",
